<% content_for :title, "グループを作成 | Okanjo" %>

<div class="w-full max-w-md mx-auto">
  <h1 class="text-2xl font-bold mb-6">グループを作成</h1>

  <%= form_with model: @group, data: { controller: "member-form" } do |f| %>
    <% if @group.errors.any? %>
      <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded text-red-700 text-sm">
        <% @group.errors.full_messages.each do |msg| %>
          <p><%= msg %></p>
        <% end %>
      </div>
    <% end %>

    <div class="mb-4">
      <%= f.label :name, "グループ名", class: "block text-sm font-medium mb-1" %>
      <%= f.text_field :name, class: "w-full border rounded px-3 py-2 text-sm", placeholder: "例: GW京都旅行" %>
    </div>

    <div class="mb-6">
      <%= f.label :memo, "メモ（任意）", class: "block text-sm font-medium mb-1" %>
      <%= f.text_area :memo, rows: 2, class: "w-full border rounded px-3 py-2 text-sm", placeholder: "備考など" %>
    </div>

    <div class="mb-6">
      <p class="text-sm font-medium mb-2">メンバーを追加（あとから追加もできます）</p>

      <div class="flex gap-2 mb-3">
        <input type="text"
               placeholder="名前"
               class="flex-1 border rounded px-3 py-2 text-sm"
               data-member-form-target="nameInput" />
        <button type="button"
                class="btn-secondary"
                data-action="click->member-form#addMember">
          追加
        </button>
      </div>

      <ul class="space-y-1" data-member-form-target="memberList"></ul>
      <div data-member-form-target="fields"></div>
    </div>

    <%= f.submit "グループを作成する →", class: "btn-primary w-full py-3" %>
  <% end %>

  <% if Rails.env.development? %>
    <div class="mt-10 pt-6 border-t border-dashed border-gray-300">
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-3">開発用サンプル</p>
      <ul class="space-y-2">
        <% [
          { token: "seed-demo1", label: "GW京都旅行",    note: "精算あり（複雑）" },
          { token: "seed-demo2", label: "忘年会",        note: "精算なし（均等割り）" },
          { token: "seed-demo3", label: "ランチ割り勘",  note: "精算あり（シンプル）" },
          { token: "seed-demo4", label: "計画中グループ", note: "精算なし（支払いゼロ）" },
        ].each do |s| %>
          <li class="flex items-center justify-between text-sm bg-gray-50 rounded px-3 py-2">
            <span><%= s[:label] %> <span class="text-gray-400 text-xs">— <%= s[:note] %></span></span>
            <div class="flex gap-3">
              <a href="<%= group_show_path(s[:token]) %>" class="text-blue-500 hover:underline">詳細</a>
              <a href="<%= group_settlements_path(s[:token]) %>" class="text-blue-500 hover:underline">精算</a>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>
</div>
