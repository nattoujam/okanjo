<% content_for :title, "#{@group.name} | Okanjo" %>

<div class="w-full max-w-md mx-auto">
  <div class="mb-6">
    <h1 class="text-2xl font-bold"><%= @group.name %></h1>
    <% if @group.memo.present? %>
      <p class="text-sm text-gray-500 mt-1"><%= @group.memo %></p>
    <% end %>
    <% if flash[:alert] %>
      <p class="text-sm text-red-600 mt-2"><%= flash[:alert] %></p>
    <% end %>
  </div>

  <div class="mb-6">
    <p class="text-sm font-medium mb-2">メンバー</p>
    <ul class="flex flex-wrap gap-2 mb-3">
      <% @group.members.each do |member| %>
        <li class="flex items-center gap-1 bg-gray-100 rounded-full px-3 py-1 text-sm">
          <%= member.name %>
          <%= button_to "&times;".html_safe,
              group_member_path(@group.token, member),
              method: :delete,
              class: "text-gray-400 hover:text-red-500 ml-1",
              form: { data: { turbo_confirm: "#{member.name}を削除しますか？" } } %>
        </li>
      <% end %>
    </ul>
    <%= form_with url: group_members_path(@group.token), method: :post, class: "flex gap-2" do |f| %>
      <%= f.text_field :name,
          name: "member[name]",
          placeholder: "名前",
          class: "flex-1 border rounded px-3 py-2 text-sm" %>
      <%= f.submit "追加", class: "btn-secondary" %>
    <% end %>
  </div>

  <div class="flex gap-2 mb-6">
    <a href="<%= new_group_payment_path(@group.token) %>" class="btn-primary flex-1 text-center">
      + 立替払いを追加
    </a>
    <a href="#" class="btn-secondary flex-1 text-center">
      精算する
    </a>
  </div>

  <section>
    <h2 class="text-sm font-semibold text-gray-500 mb-3">立替払い一覧</h2>

    <% if @group.payments.empty? %>
      <p class="text-center text-gray-400 text-sm py-10">まだ立替払いがありません</p>
    <% else %>
      <ul class="space-y-3">
        <% @group.payments.order(created_at: :desc).each do |payment| %>
          <li class="bg-white border rounded-lg px-4 py-3">
            <div class="flex justify-between items-start">
              <div>
                <span class="text-xs text-gray-500"><%= payment.payer.name %></span>
                <p class="font-medium"><%= payment.description %></p>
                <p class="text-xs text-gray-400 mt-1">
                  対象: <%= payment.payment_participants.map { |pp| pp.member.name }.join(", ") %>
                </p>
              </div>
              <div class="text-right">
                <p class="font-bold"><%= number_with_delimiter(payment.amount) %>円</p>
                <a href="<%= edit_group_payment_path(@group.token, payment) %>" class="text-xs text-blue-500 hover:underline mt-1 inline-block">編集</a>
              </div>
            </div>
          </li>
        <% end %>
      </ul>

      <div class="mt-4 pt-4 border-t text-sm text-gray-600">
        <div class="flex justify-between">
          <span>合計</span>
          <span class="font-bold"><%= number_with_delimiter(@group.payments.sum(:amount)) %>円</span>
        </div>
        <% if @group.members.any? %>
          <div class="flex justify-between mt-1">
            <span>一人あたり</span>
            <span><%= number_with_delimiter((@group.payments.sum(:amount).to_f / @group.members.count).round) %>円</span>
          </div>
        <% end %>
      </div>
    <% end %>
  </section>
</div>
