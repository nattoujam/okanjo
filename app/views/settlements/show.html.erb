<% content_for :title, "精算結果 — #{@group.name} | Okanjo" %>

<div class="w-full max-w-md mx-auto">
  <div class="mb-6">
    <a href="<%= group_show_path(@group.token) %>" class="text-sm text-gray-500 hover:text-gray-700">← <%= @group.name %></a>
    <h1 class="text-2xl font-bold mt-2">精算結果</h1>
  </div>

  <% if @repayments.empty? %>
    <div class="bg-green-50 border border-green-200 rounded-lg px-4 py-6 text-center mb-6">
      <p class="text-green-700 font-medium">精算の必要はありません！</p>
      <p class="text-sm text-green-600 mt-1">全員の収支がつり合っています</p>
    </div>
  <% else %>
    <div class="mb-2 text-sm text-gray-500">
      最小 <span class="font-bold text-gray-800"><%= @repayments.size %></span> 回の支払いで精算できます
    </div>

    <ul class="space-y-3 mb-6">
      <% @repayments.each do |r| %>
        <li class="bg-white border rounded-lg px-4 py-3 flex justify-between items-center">
          <div class="flex items-center gap-2">
            <span class="font-medium"><%= r[:from].name %></span>
            <span class="text-gray-400">→</span>
            <span class="font-medium"><%= r[:to].name %></span>
          </div>
          <span class="font-bold"><%= number_with_delimiter(r[:amount]) %>円</span>
        </li>
      <% end %>
    </ul>
  <% end %>

  <section class="mb-8">
    <h2 class="text-sm font-semibold text-gray-500 mb-3">各自の収支</h2>
    <ul class="space-y-2">
      <% @balances.each do |b| %>
        <li class="flex justify-between items-center text-sm py-1 border-b last:border-b-0">
          <span><%= b[:member].name %></span>
          <span class="font-medium <%= b[:balance] >= 0 ? 'text-blue-600' : 'text-red-500' %>">
            <%= b[:balance] >= 0 ? '+' : '' %><%= number_with_delimiter(b[:balance]) %>円
          </span>
        </li>
      <% end %>
    </ul>
  </section>

</div>
